# AutoDirector local environment

# Optional local server binding.
AUTODIRECTOR_HOST=127.0.0.1
AUTODIRECTOR_PORT=8787
AUTODIRECTOR_PUBLIC_ORIGIN=http://127.0.0.1:8787

# Optional local state/workspace locations.
# AUTODIRECTOR_STATE_DIR=.autodirector
# AUTODIRECTOR_CODEX_WORKDIR=~/.autodirector/codex-workspaces/Glitch-AutoDirector
# AUTODIRECTOR_CODEX_SESSION_DIR=~/.autodirector/codex-sessions/Glitch-AutoDirector
# AUTODIRECTOR_HYPERFRAMES_SKILL_DIR=

# Optional request hardening.
AUTODIRECTOR_MAX_JSON_BODY_BYTES=1048576

# Optional public healthcheck target for your own deployed showcase.
# AUTODIRECTOR_PUBLIC_URL=https://your-public-showcase.example.com

# Model provider routes.
# Default: Codex Native uses the user's local Codex/ChatGPT login.
# Offline verification also requires no API key.
# AUTODIRECTOR_CODEX_MODEL=

# Optional API-key provider routes.
# AUTODIRECTOR_OPENAI_TEXT_MODEL=gpt-4o-mini
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# DASHSCOPE_API_KEY=
# QWEN_API_KEY=
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

# Optional OpenAI-compatible/custom endpoint.
# CUSTOM_MODEL_BASE_URL=https://your-endpoint.example.com/v1
# CUSTOM_MODEL_API_KEY=
# CUSTOM_MODEL_NAME=
